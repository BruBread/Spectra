{
  "name": "backend-spectra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"test/**/*.test.ts\"",
    "test:e2e-server": "tsx test/support/e2eServer.ts",
    "purge:retired-alerts": "tsx scripts/purgeRetiredAlerts.ts"
  },
  "dependencies": {
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.3.0",
    "js-aruco2": "^2.0.0",
    "mongoose": "^9.7.4",
    "morgan": "^1.11.0",
    "mqtt": "^5.15.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "mongodb-memory-server": "^11.2.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
