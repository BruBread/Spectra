APP_ENV=production
PORT=4000

MONGODB_URI=mongodb+srv://<prod-db-user>:<prod-db-password>@<prod-cluster-host>/spectra_prod?retryWrites=true&w=majority

CORS_ORIGIN=https://spectra.example.com

TTN_WEBHOOK_SECRET=<prod-ttn-webhook-secret>
CHIRPSTACK_WEBHOOK_SECRET=<prod-chirpstack-webhook-secret>

MQTT_ENABLED=false
MQTT_PROVIDER=ttn
MQTT_BROKER_URL=mqtts://<prod-mqtt-broker-host>:8883
MQTT_USERNAME=<prod-mqtt-username>
MQTT_PASSWORD=<prod-mqtt-password>
MQTT_TOPIC=v3/+/devices/+/up

# --- Authentication ---
# Signs the session cookie. Generate a unique random value per deployment:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-32-byte-hex-value
SESSION_COOKIE_NAME=spectra.sid
SESSION_TTL_HOURS=12
# secure=true requires HTTPS. samesite=none (cross-domain frontend) requires secure=true.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

# Bootstrap admin, created only when no user exists yet.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=replace-me

# --- Device readings access (non-browser clients, e.g. the iOS app) ---
# Both settings below are DEVELOPMENT-ONLY and are refused at startup when
# APP_ENV=production — the server will not boot if either is set here.
#
# Production mobile/guest access is not available yet. It requires future
# per-guest authentication issuing short-lived, device-scoped access tokens
# (a static shared key identifies an app build, not an individual guest, and
# cannot express which devices a guest is entitled to).
# See README > Device readings access.
MOBILE_API_KEY=
LORAWAN_READINGS_ALLOW_ANONYMOUS=false

# --- Wristband haptic commands (Pi + SX1278 bridge) ---
# Simulated haptic delivery is REFUSED at startup in production — the server
# will not boot if this is set to true. Real delivery is the Pi + SX1278 bridge.
DEVICE_SIMULATION_ENABLED=false
# REQUIRED in production: the Raspberry Pi bridge authenticates with it, and
# without it the bridge endpoints are closed. Unique random value; never reuse a
# webhook secret. See docs/pi-sx1278-bridge.md.
DEVICE_BRIDGE_SECRET=<prod-device-bridge-shared-secret>
DEVICE_COMMAND_TTL_SECONDS=120
