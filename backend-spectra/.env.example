# Copy this file to .env.local / .env.development / .env.production and
# fill in real values. Never commit the real files.
#
# Ready-made per-environment templates are also provided:
#   .env.local.example       -> copy to .env.local        (APP_ENV=local)
#   .env.development.example -> copy to .env.development  (APP_ENV=development)
#   .env.production.example  -> copy to .env.production   (APP_ENV=production)

# Which environment config file to load: local | development | production
APP_ENV=local

# HTTP server port
PORT=4000

# MongoDB connection string.
# LOCAL must always point at 127.0.0.1, e.g. mongodb://127.0.0.1:27017/spectra_local
MONGODB_URI=mongodb://127.0.0.1:27017/spectra_local

# Allowed CORS origin(s) for the frontend
CORS_ORIGIN=*

# --- LoRaWAN ingest module -------------------------------------------------

# Shared secret the network server sends back on every webhook request.
# Configure the same value as a custom header (X-Webhook-Secret) on the
# webhook integration in The Things Stack / ChirpStack.
TTN_WEBHOOK_SECRET=changeme-ttn-webhook-secret
CHIRPSTACK_WEBHOOK_SECRET=changeme-chirpstack-webhook-secret

# Optional MQTT client (alternative to webhooks): subscribes directly to the
# network server's application MQTT broker.
MQTT_ENABLED=false
MQTT_PROVIDER=ttn
MQTT_BROKER_URL=mqtts://broker.example.com:8883
MQTT_USERNAME=changeme-mqtt-username
MQTT_PASSWORD=changeme-mqtt-password
MQTT_TOPIC=v3/+/devices/+/up
