# Copy this file to .env.local / .env.development / .env.production and
# fill in real values. Never commit the real files.
#
# Ready-made per-environment templates are also provided:
#   .env.local.example       -> copy to .env.local        (APP_ENV=local)
#   .env.development.example -> copy to .env.development  (APP_ENV=development)
#   .env.production.example  -> copy to .env.production   (APP_ENV=production)

# Which environment config file to load: local | development | production
APP_ENV=local

# HTTP server port
PORT=4000

# MongoDB connection string.
# LOCAL must always point at 127.0.0.1, e.g. mongodb://127.0.0.1:27017/spectra_local
MONGODB_URI=mongodb://127.0.0.1:27017/spectra_local

# Allowed CORS origin(s) for the frontend
CORS_ORIGIN=*

# --- LoRaWAN ingest module -------------------------------------------------

# Shared secret the network server sends back on every webhook request.
# Configure the same value as a custom header (X-Webhook-Secret) on the
# webhook integration in The Things Stack / ChirpStack.
TTN_WEBHOOK_SECRET=changeme-ttn-webhook-secret
CHIRPSTACK_WEBHOOK_SECRET=changeme-chirpstack-webhook-secret

# Optional MQTT client (alternative to webhooks): subscribes directly to the
# network server's application MQTT broker.
MQTT_ENABLED=false
MQTT_PROVIDER=ttn
MQTT_BROKER_URL=mqtts://broker.example.com:8883
MQTT_USERNAME=changeme-mqtt-username
MQTT_PASSWORD=changeme-mqtt-password
MQTT_TOPIC=v3/+/devices/+/up

# --- Authentication ---
# Signs the session cookie. Generate a unique random value per deployment:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-32-byte-hex-value
SESSION_COOKIE_NAME=spectra.sid
SESSION_TTL_HOURS=12
# secure=true requires HTTPS. samesite=none (cross-domain frontend) requires secure=true.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Bootstrap admin, created only when no user exists yet.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@spectra.com
ADMIN_PASSWORD=replace-me

# --- Device readings access (non-browser clients, e.g. the iOS app) ---
# DEVELOPMENT-ONLY. Both settings are refused at startup when APP_ENV=production.
#
# MOBILE_API_KEY is a temporary bridge: callers using it must request a
# specific ?deviceId= and cannot list all devices. It identifies an app build,
# not a guest — production requires future per-guest, short-lived,
# device-scoped access tokens instead. See README > Device readings access.
# Leave empty to disable key access entirely.
MOBILE_API_KEY=replace-with-a-random-value
# Restores the old fully-public reads for an already-deployed client that has
# no credential to send. Insecure — exposes every device's readings.
# Off by default; prohibited in production.
LORAWAN_READINGS_ALLOW_ANONYMOUS=false

# --- Wristband haptic commands (Pi + SX1278 bridge) ---
# See docs/pi-sx1278-bridge.md for the full message contract.
#
# DEVICE_SIMULATION_ENABLED runs the fake in-process transport that fabricates
# a labelled wristband round-trip for local demos. Defaults on in
# local/development, and is REFUSED at startup when APP_ENV=production — it must
# never run against real hardware.
DEVICE_SIMULATION_ENABLED=true
# Shared secret the future Raspberry Pi bridge signs its requests with. Distinct
# from any webhook secret — never reuse one. Empty means the bridge endpoints
# refuse every caller (the safe default while no bridge exists). Required in
# production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DEVICE_BRIDGE_SECRET=
# How long a queued haptic command stays deliverable before it goes stale.
DEVICE_COMMAND_TTL_SECONDS=120
