APP_ENV=development
PORT=4000

MONGODB_URI=mongodb+srv://<dev-db-user>:<dev-db-password>@<dev-cluster-host>/spectra_dev?retryWrites=true&w=majority

CORS_ORIGIN=https://dev.spectra.example.com

TTN_WEBHOOK_SECRET=<dev-ttn-webhook-secret>
CHIRPSTACK_WEBHOOK_SECRET=<dev-chirpstack-webhook-secret>

MQTT_ENABLED=false
MQTT_PROVIDER=ttn
MQTT_BROKER_URL=mqtts://<dev-mqtt-broker-host>:8883
MQTT_USERNAME=<dev-mqtt-username>
MQTT_PASSWORD=<dev-mqtt-password>
MQTT_TOPIC=v3/+/devices/+/up
