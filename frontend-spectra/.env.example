# Copy this file to .env.local / .env.development / .env.production and
# fill in real values. Never commit the real files.
#
# Next.js loads .env.local in every environment, and additionally loads
# .env.development or .env.production based on NODE_ENV automatically.
#
# Ready-made per-environment templates are also provided:
#   .env.local.example       -> copy to .env.local
#   .env.development.example -> copy to .env.development
#   .env.production.example  -> copy to .env.production

# Base URL of the backend API. LOCAL should point at 127.0.0.1 to match the
# backend's local MongoDB/server binding.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000
